{
  "name": "gemma-witness",
  "private": true,
  "version": "0.0.0",
  "description": "Repo-level orchestration scripts. Per-app dependencies live under apps/*.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "setup": "node scripts/setup.mjs",
