# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.uv/

# Node
node_modules/
dist/
build/

# Rust
target/
Cargo.lock.bak

# Editor
.vscode/
.idea/

# Logs and runtime artifacts (gate evidence under evidence/ is committed)
*.pid
sidecar.log
*.tmp

# Local model caches (HF cache lives in ~/.cache/huggingface by default)
inference/mlx-sidecar/models/

# Tauri generated
apps/capture/src-tauri/gen/
apps/capture/dist/

# Internal planning docs (keep local, not for the public repo)
LIMITATIONS-RESOLUTION.md
SECURITY-AUDIT.md

# Demo bundle artifacts. The journal, screenshots, and CHECKSUMS.txt under
# evidence/demo-*/ are committed for reproducibility; the .witness binaries
# they describe are regenerated locally and not tracked.
evidence/demo-*/bundles/

# Secrets and key material. Test fixtures under tests/fixtures/ are exempt so
# round-trip fixtures stay tracked.
.env
.env.local
*.pem
*.key
id_ed25519*
*.witness
!tests/fixtures/**/*.witness
