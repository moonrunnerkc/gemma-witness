{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemma-witness.dev/spec/manifest-schema.json",
  "title": "WitnessManifest",
  "description": "Signed root document for a Gemma.Witness bundle. The Ed25519 signature stored in signature.json covers the RFC 8785 JCS canonicalization of this object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "bundle_id",
    "created_at",
    "signer",
    "assets",
    "assertions"
  ],
  "properties": {
    "manifest_version": {
      "description": "Integer schema version. The verifier routes on this; bump on every incompatible change.",
      "type": "integer",
      "const": 1
    },
    "bundle_id": {
      "description": "UUID v4 identifying this bundle.",
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "created_at": {
      "description": "ISO 8601 timestamp at which the manifest was sealed.",
      "type": "string",
      "format": "date-time"
    },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "public_key_pem", "key_id"],
      "properties": {
        "algorithm": { "type": "string", "const": "ed25519" },
        "public_key_pem": { "type": "string", "minLength": 1 },
        "key_id": {
          "description": "SHA-256 of the raw 32-byte public key, lowercase hex.",
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "assets": {
      "description": "Every binary file inside the bundle, keyed by its in-zip path. Hash is SHA-256 of the raw file bytes.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "media_type", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "media_type": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "assertions": {
      "description": "Namespaced assertions about the captured evidence.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gemma.witness.model_fingerprint",
        "gemma.witness.incident_report",
        "gemma.witness.reasoning_trace",
        "gemma.witness.consistency_verdict",
        "gemma.witness.capture_environment"
      ],
      "properties": {
        "gemma.witness.model_fingerprint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model_id", "revision", "sha256"],
          "properties": {
            "model_id": { "type": "string", "minLength": 1 },
            "revision": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        },
        "gemma.witness.incident_report": {
          "$ref": "incident-schema.json"
        },
        "gemma.witness.reasoning_trace": {
          "type": "object",
          "additionalProperties": false,
          "required": ["asset_path", "sha256", "bytes"],
          "properties": {
            "asset_path": { "type": "string", "minLength": 1 },
            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "bytes": { "type": "integer", "minimum": 0 }
          }
        },
        "gemma.witness.consistency_verdict": {
          "type": "object",
          "additionalProperties": false,
          "required": ["verdict"],
          "properties": {
            "verdict": { "type": "string", "enum": ["consistent", "inconsistent"] },
            "summary": { "type": "string" }
          }
        },
        "gemma.witness.capture_environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "app_version", "captured_at"],
          "properties": {
            "os": { "type": "string", "minLength": 1 },
            "hostname": { "type": "string" },
            "app_version": { "type": "string", "minLength": 1 },
            "captured_at": { "type": "string", "format": "date-time" }
          }
        },
        "gemma.witness.audio_fingerprint": {
          "description": "Optional advisory perceptual fingerprint of the captured audio. Not a security primitive; the SHA-256 in the audio asset entry remains the cryptographic guarantee. Verifiers display the field and may offer an opt-in re-derivation check.",
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value", "note"],
          "properties": {
            "algorithm": { "type": "string", "enum": ["gw-spectral-v1"] },
            "value": { "type": "string", "minLength": 1 },
            "note": { "type": "string", "minLength": 1 }
          }
        },
        "gemma.witness.inference_parameters": {
          "description": "Optional advisory assertion recording the sampling parameters used by each inference pass. Forensic, not cryptographic; verifiers display it without passing or failing on its contents.",
          "type": "object",
          "additionalProperties": false,
          "required": ["passes", "note"],
          "properties": {
            "passes": {
              "description": "Per-pass parameters keyed by pass name (transcribe, structure_incident, analyze_image, check_consistency).",
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["temperature", "max_tokens", "prompt_sha256"],
                "properties": {
                  "temperature": { "type": "number", "minimum": 0 },
                  "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
                  "max_tokens": { "type": "integer", "minimum": 1 },
                  "visual_token_budget": { "type": "integer", "minimum": 1 },
                  "prompt_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
                }
              }
            },
            "sampling_seed": {
              "description": "RNG seed if pinned. Null today across every pass.",
              "type": ["integer", "null"],
              "minimum": 0
            },
            "note": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
