{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemma-witness.dev/spec/incident-schema.json",
  "title": "IncidentReport",
  "description": "Structured incident report extracted from a witness transcript.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp",
    "location",
    "incident_type",
    "narrative_summary",
    "severity",
    "evidence_references"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the incident occurred."
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "witness_contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "phone": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email", "minLength": 1 }
      }
    },
    "incident_type": {
      "type": "string",
      "enum": [
        "safety_hazard",
        "environmental",
        "labor",
        "harassment",
        "property_damage",
        "other"
      ]
    },
    "narrative_summary": {
      "type": "string",
      "minLength": 20
    },
    "severity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "notes": {
      "type": "string"
    },
    "evidence_references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "sha256"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["audio", "image", "video", "document", "other"]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
