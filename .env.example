# Sidecar HTTP endpoint. The capture app, CLI, and eval harness default to this.
# Evidence: crates/witness-inference/src/http.rs (DEFAULT_ENDPOINT).
GW_SIDECAR_ENDPOINT=http://127.0.0.1:8080

# Sidecar bind host and port. Read by inference/*/start.sh.
GW_SIDECAR_HOST=127.0.0.1
GW_SIDECAR_PORT=8080

# Model id passed to the sidecar.
# mlx path:        mlx-community/gemma-4-e4b-it-4bit
# mistralrs path:  google/gemma-4-E4B-it
# transformers:    google/gemma-4-E4B-it
GW_SIDECAR_MODEL=mlx-community/gemma-4-e4b-it-4bit

# Optional: increase Rust log verbosity from the capture app and CLI.
# Evidence: crates/witness-cli/src/main.rs uses tracing_subscriber::EnvFilter.
RUST_LOG=info
